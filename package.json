{
  "name": "kimbo-terminal",
  "version": "0.2.1",
  "description": "A fast, themeable terminal emulator built with Rust and Tauri",
  "author": "Luca Tescari",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lucatescari/kimbo-terminal.git"
  },
  "type": "module",
  "scripts": {
    "start": "cargo tauri dev",
    "build": "cargo tauri build",
    "dev": "vite",
    "build:frontend": "tsc && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rust": "cargo test -p kimbo-terminal -p kimbo-config",
    "test:all": "vitest run && cargo test -p kimbo-terminal -p kimbo-config",
    "release": "./scripts/release.sh",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^5.5.0"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.6.0",
    "jsdom": "^29.0.2",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.4"
  }
}
