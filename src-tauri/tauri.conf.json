{
  "$schema": "https://raw.githubusercontent.com/nicobrinkkemper/tauri-v2-schema/main/tauri.conf.json",
  "productName": "Kimbo",
  "version": "0.2.0",
  "identifier": "com.kimbo.terminal",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:frontend"
  },
  "app": {
    "windows": [
      {
        "title": "Kimbo",
        "width": 1200,
        "height": 800,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/shell/kimbo-init.zsh",
      "resources/shell/kimbo-init.bash",
      "resources/shell/kimbo-init.fish"
    ]
  }
}
