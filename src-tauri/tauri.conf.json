{
  "$schema": "https://raw.githubusercontent.com/nicobrinkkemper/tauri-v2-schema/main/tauri.conf.json",
  "productName": "Kimbo",
  "version": "0.9.0",
  "identifier": "com.kimbo.terminal",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:frontend"
  },
  "app": {
    "windows": [
      {
        "title": "Kimbo",
        "width": 1200,
        "height": 800,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "minWidth": 600,
        "minHeight": 400
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/shell/kimbo-init.zsh",
      "resources/shell/kimbo-init.bash",
      "resources/shell/kimbo-init.fish"
    ],
    "macOS": {
      "entitlements": "entitlements.plist"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/lucatescari/kimbo-terminal/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFGMjJBQTJEMzQ5QzJCNjAKUldSZ0s1dzBMYW9pSDJVUFpxM1U2NU9SMkNqc3BON3F5ZzYrQ1k2Vk5jblpmT2tKdWtGSDF3d3oK"
    }
  }
}
