{
  "identifier": "default",
  "description": "Default capabilities for Kimbo terminal",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "core:event:default",
    "opener:default",
    "opener:allow-open-url",
    "updater:default",
    "process:allow-restart"
  ]
}
